<UserControl
    x:Class="TyfloCentrum.Windows.App.Views.RadioSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    PreviewKeyDown="OnPreviewKeyDown"
    mc:Ignorable="d">
    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontWeight="SemiBold"
            Text="Bieżący status Tyfloradia i aktualna ramówka."
            TextWrapping="WrapWholeWords" />

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="ListenButton"
                AutomationProperties.AutomationId="radio.listen"
                AutomationProperties.Name="Posłuchaj Tyfloradia"
                Click="OnOpenStreamClick"
                Content="Posłuchaj Tyfloradia" />
            <Button
                x:Name="ContactButton"
                AutomationProperties.AutomationId="radio.contact"
                AutomationProperties.Name="Skontaktuj się z Tyfloradiem"
                Click="OnOpenContactClick"
                Content="Skontaktuj się z Tyfloradiem" />
            <Button
                x:Name="VoiceContactButton"
                AutomationProperties.AutomationId="radio.contactVoice"
                AutomationProperties.Name="Nagraj głosówkę do Tyfloradia"
                Click="OnOpenVoiceContactClick"
                Content="Nagraj głosówkę" />
            <Button
                x:Name="RefreshButton"
                AutomationProperties.AutomationId="radio.refresh"
                AutomationProperties.Name="Odśwież dane Tyfloradia"
                Click="OnRefreshClick"
                Content="Odśwież" />
        </StackPanel>

        <TextBlock
            x:Name="AnnouncementTextBlock"
            Grid.Row="2"
            AutomationProperties.LiveSetting="Polite"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="{Binding StatusAnnouncement}"
            TextWrapping="WrapWholeWords"
            Visibility="Collapsed" />

        <ProgressRing
            x:Name="LoadingIndicator"
            Grid.Row="2"
            HorizontalAlignment="Left"
            IsActive="False"
            Visibility="Collapsed" />

        <StackPanel
            x:Name="ErrorPanel"
            Grid.Row="3"
            Spacing="8"
            Visibility="Collapsed">
            <InfoBar
                x:Name="ErrorBar"
                AutomationProperties.AutomationId="radio.error"
                IsClosable="False"
                IsIconVisible="False"
                IsOpen="False"
                Severity="Error"
                Title="Problem w sekcji Tyfloradio" />
        </StackPanel>

        <StackPanel
            Grid.Row="4"
            Spacing="12">
            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="Status audycji interaktywnej" />
                    <ScrollViewer
                        AutomationProperties.AutomationId="radio.current"
                        AutomationProperties.Name="{Binding LiveStatusAccessibleText}"
                        HorizontalScrollBarVisibility="Disabled"
                        IsTabStop="True"
                        MinHeight="96"
                        VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            Text="{Binding LiveStatusDisplayText}"
                            TextWrapping="WrapWholeWords" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border
                Padding="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="Ramówka" />
                    <Button
                        x:Name="ScheduleButton"
                        AutomationProperties.AutomationId="radio.schedule"
                        AutomationProperties.Name="Pokaż ramówkę Tyfloradia"
                        Click="OnOpenScheduleClick"
                        KeyDown="OnScheduleButtonKeyDown"
                        Content="Pokaż ramówkę Tyfloradia" />
                    <TextBox
                        x:Name="ScheduleEditor"
                        AutomationProperties.AutomationId="radio.scheduleEditor"
                        AutomationProperties.Name="Treść ramówki Tyfloradia"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        MinHeight="240"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        Text="{Binding ScheduleDisplayText, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Visibility="Collapsed" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
