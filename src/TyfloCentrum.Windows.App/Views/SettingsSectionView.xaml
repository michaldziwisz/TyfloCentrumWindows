<UserControl
    x:Class="TyfloCentrum.Windows.App.Views.SettingsSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    PreviewKeyDown="OnPreviewKeyDown"
    mc:Ignorable="d">
    <Grid RowSpacing="12" MaxWidth="920">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontWeight="SemiBold"
            Text="Preferencje audio dla odtwarzania, nagrywania głosówek i działania aplikacji na tym komputerze."
            TextWrapping="WrapWholeWords" />

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="RefreshDevicesButton"
                AutomationProperties.AutomationId="settings.refreshDevices"
                AutomationProperties.Name="Odśwież listę urządzeń audio"
                Click="OnRefreshDevicesClick"
                Content="Odśwież listę urządzeń" />
            <Button
                x:Name="ResetButton"
                AutomationProperties.AutomationId="settings.reset"
                AutomationProperties.Name="Przywróć domyślne ustawienia audio"
                Click="OnResetClick"
                Content="Przywróć domyślne" />
        </StackPanel>

        <TextBlock
            x:Name="StatusTextBlock"
            Grid.Row="2"
            AutomationProperties.LiveSetting="Polite"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="{Binding StatusMessage}"
            TextWrapping="WrapWholeWords"
            Visibility="Collapsed" />

        <Grid Grid.Row="3">
            <ProgressRing
                x:Name="LoadingIndicator"
                HorizontalAlignment="Left"
                IsActive="False"
                Visibility="Collapsed" />
            <StackPanel
                x:Name="ErrorPanel"
                Spacing="8"
                Visibility="Collapsed">
                <InfoBar
                    x:Name="ErrorBar"
                    AutomationProperties.AutomationId="settings.error"
                    IsClosable="False"
                    IsOpen="False"
                    Severity="Error" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="5">
            <StackPanel Spacing="16">
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            AutomationProperties.HeadingLevel="Level2"
                            FontWeight="SemiBold"
                            Text="Urządzenia audio" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Jeśli wybierzesz urządzenie domyślne, aplikacja użyje bieżącego ustawienia systemu Windows."
                            TextWrapping="WrapWholeWords" />
                        <ComboBox
                            x:Name="InputDeviceComboBox"
                            AutomationProperties.Name="Urządzenie wejściowe do głosówek"
                            DisplayMemberPath="Label"
                            Header="Urządzenie wejściowe do głosówek"
                            ItemsSource="{Binding InputDevices}"
                            MinWidth="360"
                            SelectedItem="{Binding SelectedInputDevice, Mode=TwoWay}" />
                        <ComboBox
                            x:Name="OutputDeviceComboBox"
                            AutomationProperties.Name="Urządzenie wyjściowe dla odtwarzacza"
                            DisplayMemberPath="Label"
                            Header="Urządzenie wyjściowe dla odtwarzacza"
                            ItemsSource="{Binding OutputDevices}"
                            MinWidth="360"
                            SelectedItem="{Binding SelectedOutputDevice, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            AutomationProperties.HeadingLevel="Level2"
                            FontWeight="SemiBold"
                            Text="Powiadomienia" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding NotificationsDescription}"
                            TextWrapping="WrapWholeWords" />
                        <ToggleSwitch
                            x:Name="NotifyNewPodcastsToggle"
                            AutomationProperties.Name="Powiadomienia o nowych podcastach"
                            Header="Powiadamiaj o nowych podcastach"
                            IsOn="{Binding NotifyAboutNewPodcasts, Mode=TwoWay}" />
                        <ToggleSwitch
                            x:Name="NotifyNewArticlesToggle"
                            AutomationProperties.Name="Powiadomienia o nowych artykułach"
                            Header="Powiadamiaj o nowych artykułach"
                            IsOn="{Binding NotifyAboutNewArticles, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            AutomationProperties.HeadingLevel="Level2"
                            FontWeight="SemiBold"
                            Text="Pobieranie plików" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Pusta ścieżka oznacza użycie domyślnego folderu Pobrane systemu Windows."
                            TextWrapping="WrapWholeWords" />
                        <TextBox
                            x:Name="DownloadDirectoryTextBox"
                            AutomationProperties.Name="Folder pobierania podcastów i artykułów"
                            Header="Folder pobierania"
                            PlaceholderText="Domyślny folder Pobrane systemu Windows"
                            Text="{Binding DownloadDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                x:Name="ChooseDownloadDirectoryButton"
                                AutomationProperties.AutomationId="settings.chooseDownloadDirectory"
                                AutomationProperties.Name="Wybierz folder pobierania"
                                Click="OnChooseDownloadDirectoryClick"
                                Content="Wybierz folder" />
                            <Button
                                x:Name="UseDefaultDownloadDirectoryButton"
                                AutomationProperties.AutomationId="settings.useDefaultDownloadDirectory"
                                AutomationProperties.Name="Użyj domyślnego folderu Pobrane"
                                Click="OnUseDefaultDownloadDirectoryClick"
                                Content="Użyj folderu Pobrane" />
                        </StackPanel>
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding EffectiveDownloadDirectoryDescription}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock
                            AutomationProperties.HeadingLevel="Level2"
                            FontWeight="SemiBold"
                            Text="Odtwarzanie" />
                        <ComboBox
                            x:Name="DefaultPlaybackRateComboBox"
                            AutomationProperties.Name="Domyślna prędkość odtwarzania"
                            DisplayMemberPath="Label"
                            Header="Domyślna prędkość odtwarzania"
                            ItemsSource="{Binding PlaybackRates}"
                            MinWidth="240"
                            SelectedItem="{Binding SelectedDefaultPlaybackRate, Mode=TwoWay}" />
                        <ToggleSwitch
                            x:Name="RememberLastRateToggle"
                            AutomationProperties.Name="Zapamiętuj ostatnią prędkość odtwarzania"
                            Header="Zapamiętuj ostatnią prędkość odtwarzania"
                            IsOn="{Binding RememberLastPlaybackRate, Mode=TwoWay}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding RememberedPlaybackRateDescription}"
                            TextWrapping="WrapWholeWords" />
                        <Button
                            x:Name="ClearRememberedRateButton"
                            AutomationProperties.AutomationId="settings.clearRememberedRate"
                            AutomationProperties.Name="Wyczyść zapamiętaną prędkość odtwarzania"
                            Click="OnClearRememberedRateClick"
                            Content="Wyczyść zapamiętaną prędkość"
                            HorizontalAlignment="Left" />
                        <ToggleSwitch
                            x:Name="RememberLastVolumeToggle"
                            AutomationProperties.Name="Zapamiętuj ostatnią głośność odtwarzania"
                            Header="Zapamiętuj ostatnią głośność odtwarzania"
                            IsOn="{Binding RememberLastPlaybackVolume, Mode=TwoWay}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding RememberedPlaybackVolumeDescription}"
                            TextWrapping="WrapWholeWords" />
                        <Button
                            x:Name="ClearRememberedVolumeButton"
                            AutomationProperties.AutomationId="settings.clearRememberedVolume"
                            AutomationProperties.Name="Wyczyść zapamiętaną głośność odtwarzania"
                            Click="OnClearRememberedVolumeClick"
                            Content="Wyczyść zapamiętaną głośność"
                            HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock
                            AutomationProperties.HeadingLevel="Level2"
                            FontWeight="SemiBold"
                            Text="Nagrywanie głosówek" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Aplikacja najpierw próbuje nagrywać bez systemowych ulepszeń mikrofonu. Jeśli urządzenie tego nie obsługuje, nagrywanie uruchamia się z najlepszym trybem dostępnym na danym urządzeniu."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="SaveButton"
                        AutomationProperties.AutomationId="settings.save"
                        AutomationProperties.Name="Zapisz ustawienia"
                        Click="OnSaveClick"
                        Content="Zapisz ustawienia" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
