<UserControl
    x:Class="Tyflocentrum.Windows.App.Views.PostDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    mc:Ignorable="d">
    <Grid RowSpacing="12" MaxWidth="720">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock
                FontWeight="SemiBold"
                Text="{Binding ItemKindLabel}" />
            <TextBlock
                AutomationProperties.HeadingLevel="Level2"
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="{Binding Title}"
                TextWrapping="WrapWholeWords" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding PublishedDate}" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="ListenButton"
                AutomationProperties.Name="{Binding ListenButtonLabel}"
                Click="OnOpenPlayerClick"
                Content="Słuchaj"
                Visibility="Collapsed" />
            <Button
                AutomationProperties.Name="{Binding OpenActionAutomationLabel}"
                Click="OnOpenInBrowserClick"
                Content="{Binding OpenActionButtonLabel}" />
            <Button
                AutomationProperties.Name="{Binding ShareButtonAutomationLabel}"
                Click="OnShareClick"
                Content="{Binding ShareButtonLabel}" />
            <Button
                AutomationProperties.Name="{Binding FavoriteButtonAutomationLabel}"
                Click="OnToggleFavoriteClick"
                Content="{Binding FavoriteButtonLabel}" />
            <Button
                Click="OnRetryClick"
                Content="Spróbuj ponownie" />
        </StackPanel>

        <ProgressRing
            x:Name="LoadingIndicator"
            Grid.Row="2"
            IsActive="False"
            Visibility="Collapsed" />

        <StackPanel
            x:Name="ErrorPanel"
            Grid.Row="2"
            Spacing="8"
            Visibility="Collapsed">
            <InfoBar
                x:Name="ErrorBar"
                IsClosable="False"
                IsOpen="False"
                Severity="Error" />
        </StackPanel>

        <TextBlock
            x:Name="EmptyContentText"
            Grid.Row="3"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="Brak treści do wyświetlenia."
            Visibility="Collapsed" />

        <ScrollViewer Grid.Row="4">
            <StackPanel Spacing="16">
                <TextBlock
                    x:Name="ContentTextBlock"
                    AutomationProperties.AutomationId="PostDetail.Content"
                    Text="{Binding ContentText}"
                    TextWrapping="WrapWholeWords"
                    Visibility="Collapsed" />

                <StackPanel
                    x:Name="CommentsSection"
                    Spacing="8"
                    Visibility="Collapsed">
                    <TextBlock
                        AutomationProperties.LiveSetting="Polite"
                        FontWeight="SemiBold"
                        Text="{Binding CommentsHeaderText}" />

                    <ProgressRing
                        x:Name="CommentsLoadingIndicator"
                        HorizontalAlignment="Left"
                        IsActive="False"
                        Visibility="Collapsed" />

                    <StackPanel
                        x:Name="CommentsErrorPanel"
                        Spacing="8"
                        Visibility="Collapsed">
                        <InfoBar
                            x:Name="CommentsErrorBar"
                            IsClosable="False"
                            IsOpen="False"
                            Severity="Error" />
                        <Button
                            Click="OnRetryCommentsClick"
                            Content="Spróbuj ponownie z komentarzami" />
                    </StackPanel>

                    <TextBlock
                        x:Name="CommentsEmptyText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Brak komentarzy."
                        Visibility="Collapsed" />

                    <ItemsControl
                        x:Name="CommentsItemsControl"
                        AutomationProperties.AutomationId="PostDetail.Comments"
                        Visibility="Collapsed">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="12"
                                    Margin="0,0,0,8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <StackPanel
                                        AutomationProperties.Name="{Binding AccessibleLabel}"
                                        Spacing="4">
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="{Binding AuthorName}" />
                                        <TextBlock
                                            Text="{Binding BodyPreviewText}"
                                            TextWrapping="WrapWholeWords" />
                                        <Button
                                            HorizontalAlignment="Left"
                                            AutomationProperties.Name="{Binding DetailsButtonLabel}"
                                            Click="OnOpenCommentDetailsClick"
                                            Content="Szczegóły komentarza" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
