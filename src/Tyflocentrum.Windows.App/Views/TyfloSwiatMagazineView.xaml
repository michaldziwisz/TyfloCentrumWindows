<UserControl
    x:Class="Tyflocentrum.Windows.App.Views.TyfloSwiatMagazineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    PreviewKeyDown="OnPreviewKeyDown"
    mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate x:Key="YearItemTemplate">
            <StackPanel
                AutomationProperties.AutomationId="TyfloSwiat.Year"
                AutomationProperties.Name="{Binding AccessibleLabel}"
                Orientation="Horizontal"
                Spacing="8">
                <TextBlock Text="{Binding Label}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding CountLabel}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="IssueItemTemplate">
            <Border
                Padding="12"
                Margin="0,0,0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel
                    AutomationProperties.AutomationId="TyfloSwiat.Issue"
                    AutomationProperties.Name="{Binding AccessibleLabel}"
                    Spacing="4">
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{Binding NumberLabel}" />
                    <TextBlock
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="{Binding Title}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding PublishedDate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TocItemTemplate">
            <Border
                Padding="12"
                Margin="0,0,0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel
                    AutomationProperties.AutomationId="TyfloSwiat.TocItem"
                    AutomationProperties.Name="{Binding AccessibleLabel}"
                    Spacing="4">
                    <TextBlock
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="{Binding Title}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding PublishedDate}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowSpacing="12" MaxWidth="920">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontWeight="SemiBold"
            Text="Przeglądaj roczniki i numery czasopisma TyfloŚwiat, pobieraj PDF i otwieraj artykuły ze spisu treści."
            TextWrapping="WrapWholeWords" />

        <TextBlock
            x:Name="StatusTextBlock"
            Grid.Row="1"
            AutomationProperties.LiveSetting="Polite"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="{Binding StatusMessage}"
            TextWrapping="WrapWholeWords"
            Visibility="Collapsed" />

        <Grid Grid.Row="2">
            <ProgressRing
                x:Name="LoadingIndicator"
                HorizontalAlignment="Left"
                IsActive="False"
                Visibility="Collapsed" />
            <StackPanel
                x:Name="ErrorPanel"
                Visibility="Collapsed">
                <InfoBar
                    x:Name="ErrorBar"
                    IsClosable="False"
                    IsOpen="False"
                    Severity="Error" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="Roczniki" />
                    <TextBlock
                        x:Name="YearsEmptyStateText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Brak roczników czasopisma."
                        Visibility="Collapsed" />
                    <ListView
                        x:Name="YearsList"
                        AutomationProperties.AutomationId="TyfloSwiat.Years"
                        AutomationProperties.Name="Lista roczników czasopisma TyfloŚwiat"
                        ItemTemplate="{StaticResource YearItemTemplate}"
                        ItemsSource="{Binding Years}"
                        KeyDown="OnYearsListKeyDown"
                        SelectionChanged="OnYearsListSelectionChanged"
                        SelectionMode="Single" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="Numery" />
                    <TextBlock
                        x:Name="EmptyStateText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding IssuesPlaceholderText}"
                        Visibility="Collapsed" />
                    <ListView
                        x:Name="IssuesList"
                        AutomationProperties.AutomationId="TyfloSwiat.Issues"
                        AutomationProperties.Name="Lista numerów czasopisma"
                        ContextRequested="OnIssuesListContextRequested"
                        ItemTemplate="{StaticResource IssueItemTemplate}"
                        ItemsSource="{Binding Issues}"
                        KeyDown="OnIssuesListKeyDown"
                        SelectionChanged="OnIssueSelectionChanged"
                        SelectionMode="Single" />
                </StackPanel>

                <Border
                    x:Name="IssueDetailCard"
                    Grid.Column="2"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="Wybrany numer" />
                            <TextBlock
                                x:Name="IssueTitleTextBlock"
                                AutomationProperties.HeadingLevel="Level2"
                                Style="{ThemeResource TitleTextBlockStyle}"
                                Text="{Binding SelectedIssueTitle}"
                                TextWrapping="WrapWholeWords"
                                Visibility="Collapsed" />
                            <TextBlock
                                x:Name="IssueDateTextBlock"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding SelectedIssuePublishedDate}"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <StackPanel
                            x:Name="IssueActionsPanel"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed">
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Dodatkowe akcje numeru są dostępne w menu kontekstowym."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <ProgressRing
                            x:Name="IssueLoadingIndicator"
                            HorizontalAlignment="Left"
                            IsActive="False"
                            Visibility="Collapsed" />

                        <StackPanel
                            x:Name="IssueErrorPanel"
                            Spacing="8"
                            Visibility="Collapsed">
                            <InfoBar
                                x:Name="IssueErrorBar"
                                IsClosable="False"
                                IsOpen="False"
                                Severity="Error" />
                        </StackPanel>

                        <TextBlock
                            x:Name="IssuePlaceholderText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Wybierz numer, aby wyświetlić jego treść lub spis treści."
                            Visibility="Collapsed" />

                        <StackPanel
                            x:Name="TocSection"
                            Spacing="8"
                            Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold" Text="Artykuły" />
                            <ListView
                                x:Name="TocItemsList"
                                AutomationProperties.AutomationId="TyfloSwiat.Toc"
                                AutomationProperties.Name="Lista artykułów numeru"
                                ContextRequested="OnTocItemsListContextRequested"
                                IsItemClickEnabled="True"
                                ItemClick="OnTocItemsListItemClick"
                                ItemTemplate="{StaticResource TocItemTemplate}"
                                ItemsSource="{Binding TocItems}"
                                KeyDown="OnTocItemsListKeyDown"
                                SelectionMode="Single" />
                        </StackPanel>

                        <TextBlock
                            x:Name="IssueContentTextBlock"
                            AutomationProperties.AutomationId="TyfloSwiat.Issue.Content"
                            Text="{Binding SelectedIssueContentText}"
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
