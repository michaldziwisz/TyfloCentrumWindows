<UserControl
    x:Class="Tyflocentrum.Windows.App.Views.NewsSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    PreviewKeyDown="OnPreviewKeyDown"
    mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate x:Key="NewsItemTemplate">
            <Border
                Padding="12"
                Margin="0,0,0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel
                    AutomationProperties.AutomationId="News.Item"
                    AutomationProperties.Name="{Binding AccessibleLabel}"
                    Spacing="4">
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{Binding KindLabel}" />
                    <TextBlock
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="{Binding Title}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding PublishedDate}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding Excerpt}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontWeight="SemiBold"
            Text="Najnowsze treści z Tyflopodcast i TyfloŚwiat" />

        <ProgressRing
            x:Name="LoadingIndicator"
            Grid.Row="1"
            IsActive="False"
            Visibility="Collapsed" />

        <StackPanel
            x:Name="ErrorPanel"
            Grid.Row="2"
            Spacing="8"
            Visibility="Collapsed">
            <InfoBar
                x:Name="ErrorBar"
                AutomationProperties.AutomationId="News.Error"
                IsClosable="False"
                IsOpen="False"
                Severity="Error" />
            <Button
                AutomationProperties.AutomationId="News.Retry"
                Click="OnRetryClick"
                Content="Spróbuj ponownie" />
        </StackPanel>

        <TextBlock
            x:Name="EmptyStateText"
            Grid.Row="2"
            Visibility="Collapsed"
            Text="Brak nowych treści do wyświetlenia." />

        <Grid
            Grid.Row="3"
            RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ListView
                x:Name="NewsList"
                Grid.Row="0"
                AutomationProperties.AutomationId="News.List"
                AutomationProperties.Name="Lista nowości"
                ContainerContentChanging="OnNewsListContainerContentChanging"
                ContextRequested="OnNewsListContextRequested"
                IsItemClickEnabled="True"
                ItemClick="OnNewsListItemClick"
                ItemTemplate="{StaticResource NewsItemTemplate}"
                ItemsSource="{Binding Items}"
                KeyDown="OnNewsListKeyDown"
                SelectionMode="Single" />
            <ProgressRing
                x:Name="LoadMoreIndicator"
                Grid.Row="1"
                HorizontalAlignment="Left"
                IsActive="False"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</UserControl>
