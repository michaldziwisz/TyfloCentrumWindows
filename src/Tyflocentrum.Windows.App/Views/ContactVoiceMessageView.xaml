<UserControl
    x:Class="Tyflocentrum.Windows.App.Views.ContactVoiceMessageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="RootControl"
    Loaded="OnLoaded"
    mc:Ignorable="d">
    <UserControl.KeyboardAccelerators>
        <KeyboardAccelerator
            Key="R"
            Modifiers="Control"
            Invoked="OnRecordShortcutInvoked" />
    </UserControl.KeyboardAccelerators>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="640"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="StatusTextBlock"
                Grid.Row="0"
                AutomationProperties.AutomationId="contact.voice.status"
                AutomationProperties.LiveSetting="Assertive"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="WrapWholeWords"
                Visibility="Collapsed" />

            <InfoBar
                x:Name="ErrorBar"
                Grid.Row="1"
                IsClosable="False"
                IsOpen="False"
                Severity="Error"
                Visibility="Collapsed" />

            <StackPanel
                Grid.Row="2"
                Spacing="12">
                <TextBox
                    x:Name="NameTextBox"
                    AutomationProperties.AutomationId="contact.voice.name"
                    Header="Imię"
                    PlaceholderText="Wpisz imię"
                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Border
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Nagranie" />
                        <TextBlock
                            AutomationProperties.AutomationId="contact.voice.duration"
                            Text="{Binding DurationText}" />
                        <TextBlock
                            AutomationProperties.AutomationId="contact.voice.segments"
                            Text="{Binding SegmentCountText}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                x:Name="StartButton"
                                AutomationProperties.AutomationId="contact.voice.start"
                                Click="OnStartRecordingClick"
                                Content="Rozpocznij nagrywanie" />
                            <Button
                                x:Name="AppendButton"
                                AutomationProperties.AutomationId="contact.voice.append"
                                Click="OnAppendRecordingClick"
                                Content="Dograj fragment" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                x:Name="HoldToTalkButton"
                                AutomationProperties.AutomationId="contact.voice.holdToTalk"
                                ClickMode="Press"
                                Content="Przytrzymaj i mów"
                                IsTabStop="False"
                                PointerCanceled="OnHoldToTalkPointerCanceled"
                                PointerCaptureLost="OnHoldToTalkPointerCaptureLost"
                                PointerPressed="OnHoldToTalkPointerPressed"
                                PointerReleased="OnHoldToTalkPointerReleased" />
                            <Button
                                x:Name="StopButton"
                                AutomationProperties.AutomationId="contact.voice.stop"
                                Click="OnStopRecordingClick"
                                Content="Zatrzymaj nagrywanie" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                x:Name="PreviewButton"
                                AutomationProperties.AutomationId="contact.voice.preview"
                                Click="OnTogglePreviewClick"
                                Content="Odsłuchaj" />
                            <Button
                                x:Name="DeleteButton"
                                AutomationProperties.AutomationId="contact.voice.delete"
                                Click="OnDeleteRecordingClick"
                                Content="Usuń nagranie" />
                            <Button
                                x:Name="SendButton"
                                AutomationProperties.AutomationId="contact.voice.send"
                                Click="OnSendClick"
                                Content="Wyślij głosówkę" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="3">
                <ProgressRing
                    x:Name="SendingIndicator"
                    HorizontalAlignment="Left"
                    IsActive="False"
                    Visibility="Collapsed" />

                <MediaPlayerElement
                    x:Name="PreviewPlayerElement"
                    AreTransportControlsEnabled="False"
                    AutoPlay="False"
                    Height="1"
                    Width="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    Opacity="0.01" />
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
